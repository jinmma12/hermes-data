# Database
# Supported providers for V2: postgres, sqlserver
HERMES_DB_PROVIDER=postgres
HERMES_DB_SCHEMA=hermes

# Python reference backend
DATABASE_URL=postgresql+asyncpg://hermes:<set-via-env>@localhost:5432/hermes_db

# .NET API / Engine
HERMES_DB_CONNECTION_STRING__POSTGRES=Host=localhost;Database=hermes_db;Username=hermes;Password=<set-via-env>
HERMES_DB_CONNECTION_STRING__SQLSERVER=Server=localhost,1433;Database=hermes_db;User Id=sa;Password=<set-via-env>;TrustServerCertificate=True

# If the user already has PostgreSQL or SQL Server installed, point the
# connection string to that database and do not start the Docker DB service.
HERMES_DB_USE_DOCKER=false
HERMES_POSTGRES_USER=hermes
HERMES_POSTGRES_PASSWORD=change-me-local-only
HERMES_POSTGRES_DB=hermes_db

# Application
HERMES_SECRET_KEY=change-me-in-production
HERMES_PLUGINS_DIR=../plugins
LOG_LEVEL=INFO

# External integrations (optional)
NIFI_BASE_URL=http://localhost:8080/nifi-api
